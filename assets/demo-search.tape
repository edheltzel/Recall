# demo-search.tape — Recall hybrid search demo
Output assets/demo-search.gif
Set FontSize 14
Set Width 900
Set Height 450
Set Theme "Catppuccin Mocha"
Set TypingSpeed 50ms
Set Padding 20
Set Shell "bash"
Env PATH "/Users/ed/.bun/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

Type "recall search 'session extract'"
Sleep 500ms
Enter
Sleep 3s
