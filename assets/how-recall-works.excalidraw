    {
      "type": "text",
      "id": "extract_text",
      "x": 160,
      "y": 615,
      "width": 340,
      "height": 190,
      "text": "Extraction Pipeline\n\n  Read JSONL\n  ↓  filter noise (skip tool results)\n  ↓  dedup check (.extraction_tracker)\n  ↓  Haiku extract (Ollama fallback)\n  ↓  quality gate (SUMMARY + IDEAS)",
      "originalText": "Extraction Pipeline\n\n  Read JSONL\n  ↓  filter noise (skip tool results)\n  ↓  dedup check (.extraction_tracker)\n  ↓  Haiku extract (Ollama fallback)\n  ↓  quality gate (SUMMARY + IDEAS)",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
