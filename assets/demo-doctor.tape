# demo-doctor.tape — Recall health check demo
Output assets/demo-doctor.gif
Set FontSize 14
Set Width 900
Set Height 450
Set Theme "Catppuccin Mocha"
Set TypingSpeed 50ms
Set Padding 20
Set Shell "bash"
Env PATH "/Users/ed/.bun/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

Type "recall doctor"
Sleep 500ms
Enter
Sleep 4s
