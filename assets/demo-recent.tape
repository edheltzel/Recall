# demo-recent.tape — Recall recent memory demo
Output assets/demo-recent.gif
Set FontSize 14
Set Width 900
Set Height 450
Set Theme "Catppuccin Mocha"
Set TypingSpeed 50ms
Set Padding 20
Set Shell "bash"
Env PATH "/Users/ed/.bun/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

Type "recall recent"
Sleep 500ms
Enter
Sleep 3s
